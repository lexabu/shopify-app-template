# Optional: OpenAI API key for AI features
OPENAI_API_KEY=

# Optional: Database URL for production (PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:5432/database

# Optional: Sentry for error tracking
SENTRY_DSN=
