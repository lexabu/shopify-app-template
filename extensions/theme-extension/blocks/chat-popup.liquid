{{ 'chat-styles.css' | asset_url | stylesheet_tag }}
<script src="{{ 'chat-app.js' | asset_url }}" defer></script>

<div
  class="pf-chat-popup pf-chat-popup--{{ block.settings.button_position }}"
  data-mode="popup"
  data-shop-domain="{{ shop.domain }}"
  data-primary-color="{{ block.settings.primary_color }}"
  data-welcome-message="{{ block.settings.welcome_message }}"
  data-placeholder-text="{{ block.settings.placeholder_text }}"
>
  <button class="pf-chat-toggle" type="button">
    {{ block.settings.button_text }}
  </button>
  <div class="pf-chat-panel">
    <div class="pf-chat-header">
      <span>{{ block.settings.header_text }}</span>
      <button class="pf-chat-close" type="button" aria-label="Close chat">
        ✕
      </button>
    </div>
    <div class="pf-chat-messages"></div>
    <div class="pf-chat-suggestions"></div>
    <form class="pf-chat-form">
      <input
        class="pf-chat-input"
        type="text"
        placeholder="{{ block.settings.placeholder_text }}"
        aria-label="Chat message"
        required
      >
      <button class="pf-chat-send" type="submit">Send</button>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "Product Finder Chat Popup",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Chat"
    },
    {
      "type": "select",
      "id": "button_position",
      "label": "Button position",
      "default": "bottom-right",
      "options": [
        { "value": "bottom-right", "label": "Bottom right" },
        { "value": "bottom-left", "label": "Bottom left" }
      ]
    },
    {
      "type": "text",
      "id": "header_text",
      "label": "Header text",
      "default": "Product Finder"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary color",
      "default": "#111111"
    },
    {
      "type": "text",
      "id": "welcome_message",
      "label": "Welcome message",
      "default": "Hi! How can I help you find the perfect product?"
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Placeholder text",
      "default": "Describe what you're looking for..."
    }
  ]
}
{% endschema %}
